# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env

# 1) Токен бота от @BotFather (ОБЯЗАТЕЛЬНО). НИКОГДА не коммить реальный токен!
BOT_TOKEN=PASTE_YOUR_TOKEN_FROM_BOTFATHER

# 2) База данных.
#    По умолчанию — SQLite (файл рядом с ботом, ничего настраивать не нужно):
DATABASE_URL=sqlite+aiosqlite:///bot.db
#
#    Для тысяч активных пользователей рекомендуется PostgreSQL.
#    Установи asyncpg (см. requirements.txt) и впиши строку вида:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/teammates_bot

# 3) ID администраторов через запятую (можно оставить пустым).
#    Узнать свой ID можно у бота @userinfobot
ADMIN_IDS=

# 4) Сколько жалоб нужно, чтобы анкета автоматически скрылась
REPORTS_TO_HIDE=5

# 5) Через сколько минут лайкнутая/пропущенная анкета снова попадётся в ленте
REBROWSE_COOLDOWN_MINUTES=60
